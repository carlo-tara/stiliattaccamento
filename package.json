{
  "name": "stili-attaccamento-wiki",
  "version": "1.3.0",
  "description": "Wiki sugli stili di attaccamento con integrazione immagini generate via Qwen API",
  "scripts": {
    "generate-images": "node scripts/generate-images.js",
    "generate-images:page": "node scripts/generate-images.js --page",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "inject-seo": "node scripts/inject-seo.js",
    "seo": "npm run inject-seo && npm run generate-sitemap && node scripts/validate-seo.js",
    "validate-seo": "node scripts/validate-seo.js",
    "enrich-schema-geo": "node scripts/enrich-schema-geo.js",
    "geo": "npm run enrich-schema-geo",
    "inject-performance": "node scripts/inject-performance.js",
    "perf": "npm run inject-performance",
    "inject-a11y": "node scripts/inject-a11y.js",
    "clean-wiki-inline-styles": "node scripts/clean-wiki-inline-styles.js",
    "fix-approfondimenti-nesting": "node scripts/fix-approfondimenti-nesting.js",
    "clean-approfondimenti-ui": "node scripts/clean-approfondimenti-ui.js",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:validation": "node tests/validation/run-all.cjs",
    "test:html": "node tests/validation/html-validator.js",
    "test:css": "node tests/validation/css-validator.js",
    "test:links": "node tests/validation/link-checker.js",
    "test:schema": "node tests/validation/schema-org-checker.js",
    "test:accessibility": "playwright test tests/accessibility",
    "test:all": "npm run test:unit && npm run test:e2e && npm run test:validation"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.57.0",
    "@vitest/ui": "^4.0.16",
    "axe-core": "^4.11.0",
    "html-validator": "^6.0.1",
    "jsdom": "^27.4.0",
    "playwright": "^1.57.0",
    "vitest": "^4.0.16",
    "w3c-html-validator": "^2.0.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
