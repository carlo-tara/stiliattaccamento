#!/usr/bin/env bash
# Verifica che npm run perf sia stato eseguito prima del push (artefatti allineati)

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "▶ pre-push: npm run perf..."
npm run perf

if ! git diff --quiet -- public/ || ! git diff --cached --quiet -- public/; then
  echo ""
  echo "❌ npm run perf ha modificato artefatti in public/ non committati."
  echo "   Esegui: git add -u public/ && git add public/pagefind/ && git commit -m \"chore: aggiorna artefatti build\" && git push"
  exit 1
fi

exit 0
